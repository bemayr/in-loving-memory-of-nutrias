---
import { storyblokEditable } from '@storyblok/astro';

const { blok } = Astro.props;

const imageUrl = blok.image?.filename
  ? `${blok.image.filename}/m/1600x900/smart`
  : null;
const ctaHref = blok.cta_link?.url || blok.cta_link?.cached_url || '#';
---

<section class="hero" {...storyblokEditable(blok)}>
  {imageUrl && (
    <div
      class="hero__bg"
      style={`background-image: url('${imageUrl}')`}
      aria-hidden="true"
    ></div>
  )}
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__content">
    {blok.headline && <h1 class="hero__headline">{blok.headline}</h1>}
    {blok.subheadline && <p class="hero__subheadline">{blok.subheadline}</p>}
    {blok.cta_text && (
      <a href={ctaHref} class="hero__cta">
        {blok.cta_text}
      </a>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--color-forest) 0%,
      var(--color-forest-mid) 60%,
      var(--color-river) 100%
    );
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.35;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(45, 80, 22, 0.4) 0%,
      rgba(30, 110, 140, 0.3) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
    max-width: 800px;
  }

  .hero__headline {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .hero__subheadline {
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero__cta {
    display: inline-block;
    background: var(--color-earth);
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.05rem;
    padding: 0.9rem 2.5rem;
    border-radius: 3rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .hero__cta:hover {
    background: var(--color-earth-light);
    transform: translateY(-2px);
    text-decoration: none;
  }
</style>
