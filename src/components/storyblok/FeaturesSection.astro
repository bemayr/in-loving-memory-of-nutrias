---
import { storyblokEditable } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';

const { blok } = Astro.props;
---

<section class="features" {...storyblokEditable(blok)}>
  <div class="features__inner">
    {blok.title && <h2 class="features__title">{blok.title}</h2>}
    {blok.subtitle && <p class="features__subtitle">{blok.subtitle}</p>}
    {blok.items && blok.items.length > 0 && (
      <div class="features__grid">
        {blok.items.map((item: any) => (
          <StoryblokComponent blok={item} />
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .features {
    padding: 5rem 1.5rem;
    background: var(--color-surface);
  }

  .features__inner {
    max-width: 1080px;
    margin-inline: auto;
  }

  .features__title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--color-forest);
    text-align: center;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .features__subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
</style>
